# ===========================================
# Vercel / Local Environment Variables
# ===========================================

# OpenAI (server only — never expose to frontend)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini

# Public API authentication (Bearer token for external clients)
AGRO_API_KEY=super_secret_api_key_here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://ai-agranom.vercel.app,https://agroolam.uz,https://www.agroolam.uz

# Optional: external API base URL for frontend (usually empty on Vercel)
# NEXT_PUBLIC_API_URL=
